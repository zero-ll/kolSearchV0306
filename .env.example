# LLM API configuration for Step1 -> Step2 keyword strategy generation.
# The frontend posts ProjectForm JSON to a chat-completions compatible endpoint.
VITE_LLM_API_URL="https://generativelanguage.googleapis.com/v1beta/models"
VITE_LLM_API_KEY=""
VITE_LLM_MODEL="gemini-2.5-pro"
VITE_LLM_TEMPERATURE="0.1"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
